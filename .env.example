# [TRIAD_ENV_EXAMPLE] Public surface for env variable names.
# Live values live ONLY on storage-contabo at /opt/prin7r-deploys/benchmark-intel/.env (gitignored).
# Variable names mirror payments-prototypes/.env.example so the pattern is consistent across all 20 Wave 2 projects.

# Public app URL used in provider redirects and webhook callback URLs.
NEXT_PUBLIC_APP_URL=https://benchmark-intel.prin7r.com
NEXT_PUBLIC_SITE_URL=https://benchmark-intel.prin7r.com

# NOWPayments — DEFAULT crypto rail (USDT/USDC hosted invoice + fiat-partner card on-ramp).
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# Reown / WalletConnect Cloud project ID (Wave 3 — direct-wallet fallback).
NEXT_PUBLIC_REOWN_PROJECT_ID=

# Plisio direct stablecoin invoices (Wave 3 — backup rail).
PLISIO_API_KEY=

# Merchant settlement wallets (documentation only — never hardcoded; Wave 3 fallback).
MERCHANT_USDT_TRC20_ADDRESS=
MERCHANT_USDT_ERC20_ADDRESS=
MERCHANT_USDC_ERC20_ADDRESS=
MERCHANT_USDC_POLYGON_ADDRESS=
MERCHANT_USDT_BSC_ADDRESS=
